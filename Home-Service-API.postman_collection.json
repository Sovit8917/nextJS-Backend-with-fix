{
  "info": {
    "name": "Home Service Marketplace API",
    "description": "Complete API collection for Home Service Marketplace backend",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000/api/v1" },
    { "key": "customerToken", "value": "" },
    { "key": "workerToken", "value": "" },
    { "key": "adminToken", "value": "" },
    { "key": "bookingId", "value": "" },
    { "key": "workerId", "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Send OTP (Customer)",
          "request": {
            "method": "POST", "url": "{{baseUrl}}/auth/send-otp",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\"phone\": \"+919876543210\", \"role\": \"CUSTOMER\"}" }
          }
        },
        {
          "name": "Verify OTP (Customer)",
          "event": [{ "listen": "test", "script": { "exec": [
            "var json = pm.response.json();",
            "if (json.data && json.data.token) { pm.collectionVariables.set('customerToken', json.data.token); }"
          ]}}],
          "request": {
            "method": "POST", "url": "{{baseUrl}}/auth/verify-otp",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\"phone\": \"+919876543210\", \"otp\": \"123456\", \"role\": \"CUSTOMER\"}" }
          }
        },
        {
          "name": "Send OTP (Worker)",
          "request": {
            "method": "POST", "url": "{{baseUrl}}/auth/send-otp",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\"phone\": \"+919876543211\", \"role\": \"WORKER\"}" }
          }
        },
        {
          "name": "Verify OTP (Worker)",
          "event": [{ "listen": "test", "script": { "exec": [
            "var json = pm.response.json();",
            "if (json.data && json.data.token) { pm.collectionVariables.set('workerToken', json.data.token); pm.collectionVariables.set('workerId', json.data.worker.id); }"
          ]}}],
          "request": {
            "method": "POST", "url": "{{baseUrl}}/auth/verify-otp",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\"phone\": \"+919876543211\", \"otp\": \"123456\", \"role\": \"WORKER\"}" }
          }
        },
        {
          "name": "Get Me",
          "request": {
            "method": "GET", "url": "{{baseUrl}}/auth/me",
            "header": [{ "key": "Authorization", "value": "Bearer {{customerToken}}" }]
          }
        }
      ]
    },
