    {
      "name": "Services",
      "item": [
        {
          "name": "Get All Services",
          "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/services", "query": [
            { "key": "categoryId", "value": "", "disabled": true },
            { "key": "search", "value": "", "disabled": true }
