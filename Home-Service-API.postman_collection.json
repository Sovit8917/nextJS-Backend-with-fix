        {
          "name": "Get Popular Services",
          "request": { "method": "GET", "url": "{{baseUrl}}/services/popular" }
        },
        {
          "name": "Get Service by ID",
          "request": { "method": "GET", "url": "{{baseUrl}}/services/:id" }
        }
      ]
    },
