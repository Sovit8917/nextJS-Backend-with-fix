            "body": { "mode": "raw", "raw": "{\"accountName\": \"Rajesh Kumar\", \"accountNumber\": \"1234567890\", \"ifscCode\": \"HDFC0001234\", \"bankName\": \"HDFC Bank\", \"upiId\": \"rajesh@upi\"}" }
          }
