generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  CUSTOMER
  WORKER
  ADMIN
}

enum BookingStatus {
  PENDING
  ACCEPTED
  REJECTED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
}

enum PaymentMethod {
  UPI
  CARD
  WALLET
  CASH
}

enum WorkerStatus {
  PENDING
  APPROVED
  REJECTED
  SUSPENDED
}

enum TransactionType {
  CREDIT
  DEBIT
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

model User {
  id            String    @id @default(uuid())
  phone         String    @unique
  email         String?   @unique
  name          String?
  avatar        String?
  role          Role      @default(CUSTOMER)
  isActive      Boolean   @default(true)
  isBlocked     Boolean   @default(false)
  fcmToken      String?
  language      String    @default("en")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  addresses     Address[]
  bookings      Booking[]
  reviews       Review[]
  notifications Notification[]
  wallet        Wallet?
  tickets       SupportTicket[]
  savedCards    SavedCard[]
  otps          Otp[]
}

model Worker {
  id              String        @id @default(uuid())
  phone           String        @unique
  email           String?       @unique
  name            String?
  avatar          String?
  bio             String?
  status          WorkerStatus  @default(PENDING)
  isActive        Boolean       @default(true)
  isOnline        Boolean       @default(false)
  isBlocked       Boolean       @default(false)
  fcmToken        String?
  language        String        @default("en")
  rating          Float         @default(0)
  totalReviews    Int           @default(0)
  totalJobs       Int           @default(0)
  serviceRadius   Float         @default(10)
  latitude        Float?
  longitude       Float?
  experience      Int           @default(0)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  skills          WorkerSkill[]
  documents       WorkerDocument[]
  services        WorkerService[]
  bookings        Booking[]
  reviews         Review[]
  earnings        Earning[]
  wallet          WorkerWallet?
  availability    Availability[]
  bankDetail      BankDetail?
  notifications   Notification[]
  tickets         SupportTicket[]
  workingHours    WorkingHour[]
  otps            Otp[]
}

model Otp {
  id        String   @id @default(uuid())
  phone     String
  otp       String
  expiresAt DateTime
  verified  Boolean  @default(false)
  userId    String?
  workerId  String?
  createdAt DateTime @default(now())

  user      User?    @relation(fields: [userId], references: [id])
  worker    Worker?  @relation(fields: [workerId], references: [id])
}

model Category {
  id          String    @id @default(uuid())
  name        String    @unique
  description String?
  image       String?
  icon        String?
  isActive    Boolean   @default(true)
  sortOrder   Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  services    Service[]
}

model Service {
  id             String         @id @default(uuid())
  categoryId     String
  name           String
  description    String?
  image          String?
  basePrice      Float
  priceType      String         @default("fixed")
  duration       Int            @default(60)
  isActive       Boolean        @default(true)
  sortOrder      Int            @default(0)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  category       Category       @relation(fields: [categoryId], references: [id])
  workerServices WorkerService[]
  bookingItems   BookingItem[]
}

model WorkerService {
  id        String   @id @default(uuid())
  workerId  String
  serviceId String
  price     Float?
  createdAt DateTime @default(now())

  worker    Worker   @relation(fields: [workerId], references: [id])
  service   Service  @relation(fields: [serviceId], references: [id])

  @@unique([workerId, serviceId])
}

model WorkerSkill {
  id        String   @id @default(uuid())
  workerId  String
  skill     String
  createdAt DateTime @default(now())

  worker    Worker   @relation(fields: [workerId], references: [id])
}

model WorkerDocument {
  id         String   @id @default(uuid())
  workerId   String
  type       String
  url        String
  isVerified Boolean  @default(false)
  createdAt  DateTime @default(now())

  worker     Worker   @relation(fields: [workerId], references: [id])
}

model BankDetail {
  id            String   @id @default(uuid())
  workerId      String   @unique
  accountName   String
  accountNumber String
  ifscCode      String
  bankName      String
  upiId         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  worker        Worker   @relation(fields: [workerId], references: [id])
}

model Address {
  id          String    @id @default(uuid())
  userId      String
  label       String    @default("Home")
  fullAddress String
  landmark    String?
  city        String
  state       String
  pincode     String
  latitude    Float
  longitude   Float
  isDefault   Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user        User      @relation(fields: [userId], references: [id])
  bookings    Booking[]
}

model Booking {
  id             String        @id @default(uuid())
  bookingNumber  String        @unique
  userId         String
  workerId       String?
  addressId      String?
  status         BookingStatus @default(PENDING)
  scheduledDate  DateTime
  scheduledTime  String
  description    String?
  images         String[]
  totalAmount    Float
  discountAmount Float         @default(0)
  taxAmount      Float         @default(0)
  finalAmount    Float
  couponId       String?
  notes          String?
  cancelReason   String?
  completedAt    DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  user           User          @relation(fields: [userId], references: [id])
  worker         Worker?       @relation(fields: [workerId], references: [id])
  address        Address?      @relation(fields: [addressId], references: [id])
  coupon         Coupon?       @relation(fields: [couponId], references: [id])
  items          BookingItem[]
  payment        Payment?
  review         Review?
  chatMessages   ChatMessage[]
  tracking       WorkerTracking[]
}

model BookingItem {
  id        String   @id @default(uuid())
  bookingId String
  serviceId String
  quantity  Int      @default(1)
  price     Float
  createdAt DateTime @default(now())

  booking   Booking  @relation(fields: [bookingId], references: [id])
  service   Service  @relation(fields: [serviceId], references: [id])
}

model Payment {
  id                  String        @id @default(uuid())
  bookingId           String        @unique
  amount              Float
  method              PaymentMethod @default(CASH)
  status              PaymentStatus @default(PENDING)
  razorpayOrderId     String?
  razorpayPaymentId   String?
  razorpaySignature   String?
  refundId            String?
  refundAmount        Float?
  refundedAt          DateTime?
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  booking             Booking       @relation(fields: [bookingId], references: [id])
}

model Earning {
  id         String   @id @default(uuid())
  workerId   String
  bookingId  String?
  amount     Float
  commission Float
  netAmount  Float
  date       DateTime @default(now())
  createdAt  DateTime @default(now())

  worker     Worker   @relation(fields: [workerId], references: [id])
}

model Wallet {
  id           String        @id @default(uuid())
  userId       String        @unique
  balance      Float         @default(0)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  user         User          @relation(fields: [userId], references: [id])
  transactions Transaction[]
}

model WorkerWallet {
  id           String        @id @default(uuid())
  workerId     String        @unique
  balance      Float         @default(0)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  worker       Worker        @relation(fields: [workerId], references: [id])
  transactions Transaction[]
}

model Transaction {
  id             String          @id @default(uuid())
  walletId       String?
  workerWalletId String?
  type           TransactionType
  amount         Float
  description    String
  referenceId    String?
  createdAt      DateTime        @default(now())

  wallet         Wallet?         @relation(fields: [walletId], references: [id])
  workerWallet   WorkerWallet?   @relation(fields: [workerWalletId], references: [id])
}

model Review {
  id        String   @id @default(uuid())
  bookingId String   @unique
  userId    String
  workerId  String
  rating    Int
  comment   String?
  images    String[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  booking   Booking  @relation(fields: [bookingId], references: [id])
  user      User     @relation(fields: [userId], references: [id])
  worker    Worker   @relation(fields: [workerId], references: [id])
}

model Coupon {
  id            String    @id @default(uuid())
  code          String    @unique
  description   String?
  discountType  String    @default("percentage")
  discountValue Float
  minOrderValue Float     @default(0)
  maxDiscount   Float?
  usageLimit    Int?
  usedCount     Int       @default(0)
  isActive      Boolean   @default(true)
  expiresAt     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  bookings      Booking[]
}

model Notification {
  id        String   @id @default(uuid())
  userId    String?
  workerId  String?
  title     String
  body      String
  type      String
  data      Json?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  user      User?    @relation(fields: [userId], references: [id])
  worker    Worker?  @relation(fields: [workerId], references: [id])
}

model SupportTicket {
  id          String        @id @default(uuid())
  userId      String?
  workerId    String?
  subject     String
  description String
  status      TicketStatus  @default(OPEN)
  resolvedAt  DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  user        User?         @relation(fields: [userId], references: [id])
  worker      Worker?       @relation(fields: [workerId], references: [id])
  messages    TicketMessage[]
}

model TicketMessage {
  id         String        @id @default(uuid())
  ticketId   String
  senderId   String
  senderType String
  message    String
  createdAt  DateTime      @default(now())

  ticket     SupportTicket @relation(fields: [ticketId], references: [id])
}

model ChatMessage {
  id         String   @id @default(uuid())
  bookingId  String
  senderId   String
  senderType String
  message    String
  isRead     Boolean  @default(false)
  createdAt  DateTime @default(now())

  booking    Booking  @relation(fields: [bookingId], references: [id])
}

model WorkerTracking {
  id        String   @id @default(uuid())
  bookingId String
  workerId  String
  latitude  Float
  longitude Float
  createdAt DateTime @default(now())

  booking   Booking  @relation(fields: [bookingId], references: [id])
}

model Availability {
  id        String   @id @default(uuid())
  workerId  String
  date      DateTime
  isOff     Boolean  @default(false)
  createdAt DateTime @default(now())

  worker    Worker   @relation(fields: [workerId], references: [id])
}

model WorkingHour {
  id        String  @id @default(uuid())
  workerId  String
  dayOfWeek Int
  startTime String
  endTime   String
  isOff     Boolean @default(false)

  worker    Worker  @relation(fields: [workerId], references: [id])

  @@unique([workerId, dayOfWeek])
}

model SavedCard {
  id             String   @id @default(uuid())
  userId         String
  razorpayCardId String
  last4          String
  network        String
  expiryMonth    Int
  expiryYear     Int
  createdAt      DateTime @default(now())

  user           User     @relation(fields: [userId], references: [id])
}

model Banner {
  id        String   @id @default(uuid())
  title     String
  image     String
  link      String?
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AppSetting {
  id        String   @id @default(uuid())
  key       String   @unique
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
